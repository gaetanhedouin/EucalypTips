{
  "name": "@site/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "npm run clean && next dev",
    "build": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "echo \"No tests for @site/web\"",
    "prebuild": "npm --prefix \"../../packages/types\" run build && npm --prefix \"../../packages/sdk\" run build && npm --prefix \"../../packages/ui\" run build"
  },
  "dependencies": {
    "@nouveau/sdk": "file:../../packages/sdk",
    "@nouveau/types": "file:../../packages/types",
    "@nouveau/ui": "file:../../packages/ui",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  }
}
